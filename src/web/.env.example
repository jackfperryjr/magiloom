# Web-client config for `npm run web:dev` / `web:build`.
# Copy to `src/web/.env` (git-ignored) and fill in. Vite only exposes VITE_* vars.
# Restart the dev server after changing this file.

# Game server WebSocket origin. Omit to use the built-in default
# (wss://magiserver.up.railway.app). For a LOCAL server use: ws://localhost:8787
# VITE_MAGILOOM_SERVER=ws://localhost:8787

# Gateway token — REQUIRED when the server has MAGILOOM_TOKEN set (Railway does).
# Use the same value as your magiserver .env / Railway variable. A local dev server
# with an empty MAGILOOM_TOKEN needs nothing here.
VITE_MAGILOOM_TOKEN=
